{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Esegui WpfApp",
			"type": "shell",
			"command": "dotnet run",
			"args": [
				"--project",
				"./WpfApp"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Pubblica Release (SingleFile)",
			"type": "shell",
			"command": "dotnet publish",
			"args": [
				"WpfApp",
				"-c",
				"Release",
				"-r",
				"win-x64",
				"--self-contained",
				"true",
				"-p:PublishSingleFile=true",
				"-o",
				"Publish/SingleFile"
			],
			"group": "build",
			"problemMatcher": []
		}
	]
}