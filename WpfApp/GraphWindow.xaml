<Window x:Class="WpfApp.GraphWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:oxy="http://oxyplot.org/wpf"
    Title="Charts" Height="700" Width="1100">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Parametri -->
            <RowDefinition Height="*" />    <!-- Selezione parametri -->
            <RowDefinition Height="3*" />   <!-- Grafico: 75% -->
        </Grid.RowDefinitions>

        <DockPanel Margin="0 0 0 10">
        </DockPanel>

        <ScrollViewer Grid.Row="1" Margin="0,0,0,10" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="SelectionColumns">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#ccc" BorderThickness="1" Margin="4" Padding="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#f5f5f5" Margin="0 0 8 0" Padding="4">
                                    <TextBlock Text="{Binding FileName}" FontWeight="Bold" TextAlignment="Center">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="-90" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Border>
                                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="280">
                                    <ItemsControl ItemsSource="{Binding Parameters}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Checked="ParameterCheckBox_Toggled"
                                                          Unchecked="ParameterCheckBox_Toggled" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <oxy:PlotView x:Name="PlotView" Model="{Binding}" />
            
            <!-- Draggable Legend Overlay -->
            <Canvas>
                 <Border x:Name="CustomLegend" Canvas.Right="10" Canvas.Top="10"
                         Background="#EEFFFFFF" BorderBrush="Black" BorderThickness="1" 
                         Padding="5" CornerRadius="3"
                         MouseLeftButtonDown="CustomLegend_MouseLeftButtonDown"
                         MouseMove="CustomLegend_MouseMove"
                         MouseLeftButtonUp="CustomLegend_MouseLeftButtonUp"
                         Cursor="SizeAll">
                     <StackPanel>
                         <TextBlock Text="Legend" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                         <ItemsControl x:Name="LegendList">
                             <ItemsControl.ItemTemplate>
                                 <DataTemplate>
                                     <StackPanel Orientation="Horizontal" Margin="0,2">
                                         <Rectangle Width="12" Height="12" Fill="{Binding ColorBrush}" Margin="0,0,5,0" Stroke="Black" StrokeThickness="1"/>
                                         <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                     </StackPanel>
                                 </DataTemplate>
                             </ItemsControl.ItemTemplate>
                         </ItemsControl>
                     </StackPanel>
                 </Border>
            </Canvas>

            <TextBlock x:Name="EmptyChartLabel" Text="Select at least one parameter to plot." Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
