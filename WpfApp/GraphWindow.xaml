<Window x:Class="WpfApp.GraphWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:oxy="http://oxyplot.org/wpf"
    Title="Charts" Height="700" Width="1100">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Settings -->
            <RowDefinition Height="3*" />   <!-- Selection (30%) -->
            <RowDefinition Height="7*" />   <!-- Graph (70%) -->
        </Grid.RowDefinitions>

        <DockPanel Margin="0 0 0 10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                <TextBlock Text="Format: " VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                <RadioButton x:Name="FormatDbRadio" Content="dB" GroupName="ValueFormat" IsChecked="True" Checked="Format_Changed" Margin="0,0,10,0"/>
                <RadioButton x:Name="FormatLinearRadio" Content="Linear" GroupName="ValueFormat" Checked="Format_Changed" Margin="0,0,10,0"/>
                <RadioButton x:Name="FormatImpedanceRadio" Content="Impedance" GroupName="ValueFormat" Checked="Format_Changed"/>
                <Button Content="Fit RLC" Click="CalculateRlc_Click" Margin="15,0,0,0" Padding="8,2" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                <TextBlock Text="X Axis: " VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                <RadioButton x:Name="XLinearRadio" Content="Linear" GroupName="XScale" IsChecked="True" Checked="Scale_Changed" Margin="0,0,10,0"/>
                <RadioButton x:Name="XLogRadio" Content="Logarithmic" GroupName="XScale" Checked="Scale_Changed"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Y Axis: " VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                <RadioButton x:Name="YLinearRadio" Content="Linear" GroupName="YScale" IsChecked="True" Checked="Scale_Changed" Margin="0,0,10,0"/>
                <RadioButton x:Name="YLogRadio" Content="Logarithmic" GroupName="YScale" Checked="Scale_Changed"/>
            </StackPanel>
        </DockPanel>

        <ScrollViewer Grid.Row="1" Margin="0,0,0,10" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="SelectionColumns">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#ccc" BorderThickness="1" Margin="4" Padding="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <!-- File Name (Horizontal, normal) -->
                                <Border Grid.Column="0" Background="#f5f5f5" Margin="0 0 8 0" Padding="6" MinWidth="150">
                                    <TextBlock Text="{Binding FileName}" FontWeight="Bold" TextAlignment="Left" VerticalAlignment="Center" TextWrapping="Wrap" />
                                </Border>

                                <!-- Parameters (Horizontal Wrap) -->
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Parameters}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}" Margin="0,0,15,5"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Checked="ParameterCheckBox_Toggled"
                                                      Unchecked="ParameterCheckBox_Toggled" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <oxy:PlotView x:Name="PlotView" Model="{Binding}" />
            
            <!-- Draggable Legend Overlay -->
            <Canvas>
                 <Border x:Name="CustomLegend" Canvas.Right="10" Canvas.Top="10"
                         Background="#EEFFFFFF" BorderBrush="Black" BorderThickness="1" 
                         Padding="5" CornerRadius="3"
                         MouseLeftButtonDown="CustomLegend_MouseLeftButtonDown"
                         MouseMove="CustomLegend_MouseMove"
                         MouseLeftButtonUp="CustomLegend_MouseLeftButtonUp"
                         Cursor="SizeAll">
                     <StackPanel>
                         <TextBlock Text="Legend" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                         <ItemsControl x:Name="LegendList">
                             <ItemsControl.ItemTemplate>
                                 <DataTemplate>
                                     <StackPanel Orientation="Horizontal" Margin="0,2">
                                         <Rectangle Width="12" Height="12" Fill="{Binding ColorBrush}" Margin="0,0,5,0" Stroke="Black" StrokeThickness="1"/>
                                         <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                     </StackPanel>
                                 </DataTemplate>
                             </ItemsControl.ItemTemplate>
                         </ItemsControl>
                     </StackPanel>
                 </Border>
            </Canvas>

            <TextBlock x:Name="EmptyChartLabel" Text="Select at least one parameter to plot." Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
