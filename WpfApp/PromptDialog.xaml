<Window x:Class="WpfApp.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FF2D2D30" MinWidth="320">
    <StackPanel Margin="16">
        <TextBlock x:Name="lblMessage" Foreground="White" Margin="0,0,0,10" TextWrapping="Wrap"/>
        <TextBox x:Name="txtInput" Margin="0,0,0,20" MinWidth="260"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0" Click="btnOk_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Click="btnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
