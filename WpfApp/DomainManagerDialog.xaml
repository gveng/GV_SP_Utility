<Window x:Class="WpfApp.DomainManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Power Domain Manager" SizeToContent="Height" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FF2D2D30">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Foreground="White" FontSize="13" Margin="0,0,0,10"
                   Text="Select the domains to delete. All probes and capacitors in the selected domains will be removed."
                   TextWrapping="Wrap"/>

        <!-- Domain list with checkboxes -->
        <Border DockPanel.Dock="Top" Background="#FF1E1E1E" CornerRadius="4"
                BorderBrush="#FF3E3E42" BorderThickness="1" Margin="0,0,0,12"
                MaxHeight="300">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DomainPanel" Margin="4"/>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Delete Selected" Width="120" Margin="0,0,8,0" Click="DeleteSelected_Click"
                    Background="#FFC62828" Foreground="White" FontWeight="SemiBold"
                    Padding="4,4" BorderThickness="0"/>
            <Button Content="Close" Width="80" Click="Close_Click" IsCancel="True"
                    Padding="4,4"/>
        </StackPanel>
    </DockPanel>
</Window>
