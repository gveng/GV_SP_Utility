<Window x:Class="WpfApp.RlcTuningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RLC Tuning" Height="250" Width="400"
        WindowStyle="ToolWindow" Topmost="True" ResizeMode="NoResize">
    <Grid Margin="10">
        <StackPanel VerticalAlignment="Center">
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Resistance (Esr)" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBlock x:Name="RValueText" Text="0 Ω" HorizontalAlignment="Right" Margin="0,-20,0,5" Foreground="Blue"/>
                <Slider x:Name="RSlider" IsMoveToPointEnabled="True" AutoToolTipPlacement="TopLeft"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Inductance (EsL)" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBlock x:Name="LValueText" Text="0 H" HorizontalAlignment="Right" Margin="0,-20,0,5" Foreground="Blue"/>
                <Slider x:Name="LSlider" IsMoveToPointEnabled="True" AutoToolTipPlacement="TopLeft"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Capacitance" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBlock x:Name="CValueText" Text="0 F" HorizontalAlignment="Right" Margin="0,-20,0,5" Foreground="Blue"/>
                <Slider x:Name="CSlider" IsMoveToPointEnabled="True" AutoToolTipPlacement="TopLeft"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>