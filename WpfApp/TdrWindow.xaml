<Window x:Class="WpfApp.TdrWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Analisi TDR (Time Domain Reflectometry)" Height="800" Width="1200">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Top controls and selection -->
            <RowDefinition Height="*" />    <!-- Chart area (remainder) -->
        </Grid.RowDefinitions>

        <!-- Top Area: Settings (Left) and File Selection (Right) -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- Settings -->
                <ColumnDefinition Width="*" />     <!-- File Selection -->
            </Grid.ColumnDefinitions>

            <!-- Settings Panel -->
            <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,0,10,0" VerticalAlignment="Top">
                <StackPanel Width="220">
                    <TextBlock Text="TDR Parameters" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />
                    
                    <TextBlock Text="Rise Time (s)" Margin="0,5,0,0" />
                    <TextBox x:Name="RiseTimeTextBox" Text="30e-12" Margin="0,2,0,5" />
                    
                    <TextBlock Text="System Impedance (Ω)" Margin="0,5,0,0" />
                    <TextBox x:Name="Z0TextBox" Text="50" Margin="0,2,0,5" />
                    
                    <TextBlock Text="Max Duration (s)" Margin="0,5,0,0" />
                    <TextBox x:Name="MaxDurationTextBox" Text="3e-9" Margin="0,2,0,5" />

                    <TextBlock Text="Delay (s)" Margin="0,5,0,0" />
                    <TextBox x:Name="DelayTextBox" Text="100e-12" Margin="0,2,0,5" />
                    
                    <TextBlock Text="Windowing" Margin="0,5,0,0" />
                    <ComboBox x:Name="WindowComboBox" Margin="0,2,0,10" />
                    
                    <Button x:Name="UpdateBtn" Content="Update Graph" Click="UpdateBtn_Click" Padding="5" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <!-- File Selection Panel -->
            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MinHeight="150" MaxHeight="250">
                <ItemsControl x:Name="FileSelectionControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                             <UniformGrid Rows="1" VerticalAlignment="Top"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#ccc" BorderThickness="1" Margin="4" Padding="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#f5f5f5" Margin="0 0 8 0" Padding="4">
                                        <TextBlock Text="{Binding FileName}" FontWeight="Bold" TextAlignment="Center">
                                            <TextBlock.LayoutTransform>
                                                <RotateTransform Angle="-90" />
                                            </TextBlock.LayoutTransform>
                                        </TextBlock>
                                    </Border>
                                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="200" MinWidth="100">
                                        <ItemsControl ItemsSource="{Binding Parameters}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Name}"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Checked="ParameterCheckBox_Checked"
                                                              Unchecked="ParameterCheckBox_Checked" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Chart -->
        <Grid Grid.Row="1">
            <oxy:PlotView x:Name="TdrPlot" />
            
            <!-- Draggable Legend Overlay -->
            <Canvas>
                 <Border x:Name="CustomLegend" Canvas.Right="10" Canvas.Top="10"
                         Background="#EEFFFFFF" BorderBrush="Black" BorderThickness="1" 
                         Padding="5" CornerRadius="3"
                         MouseLeftButtonDown="CustomLegend_MouseLeftButtonDown"
                         MouseMove="CustomLegend_MouseMove"
                         MouseLeftButtonUp="CustomLegend_MouseLeftButtonUp"
                         Cursor="SizeAll">
                     <StackPanel>
                         <TextBlock Text="Legend" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                         <ItemsControl x:Name="LegendList">
                             <ItemsControl.ItemTemplate>
                                 <DataTemplate>
                                     <StackPanel Orientation="Horizontal" Margin="0,2">
                                         <Rectangle Width="12" Height="12" Fill="{Binding ColorBrush}" Margin="0,0,5,0" Stroke="Black" StrokeThickness="1"/>
                                         <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                     </StackPanel>
                                 </DataTemplate>
                             </ItemsControl.ItemTemplate>
                         </ItemsControl>
                     </StackPanel>
                 </Border>
            </Canvas>

            <TextBlock x:Name="LoadingText" Text="Generating TDR..." HorizontalAlignment="Center" VerticalAlignment="Center" 
                       Background="#EEFFFFFF" Padding="20" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
