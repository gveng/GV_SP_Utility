<Window x:Class="WpfApp.DxfWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Layout Viewer" Height="800" Width="1200"
        Background="#FF1E1E1E" Foreground="White">
    <DockPanel>
        <!-- Menu + Toolbar Row -->
        <DockPanel DockPanel.Dock="Top" Background="#FFD0D0D0">
            <!-- File Menu -->
            <Menu DockPanel.Dock="Left" Background="Transparent" Foreground="Black" VerticalAlignment="Center">
                <MenuItem Header="File">
                    <MenuItem Header="Open Layout..." Click="OpenLayout_Click"/>
                    <Separator/>
                    <MenuItem Header="Save Configuration" Click="SaveConfig_Click"/>
                    <MenuItem Header="Open Configuration..." Click="LoadConfig_Click"/>
                </MenuItem>
            </Menu>

            <!-- Toolbar Buttons -->
            <ToolBarTray DockPanel.Dock="Left" Background="Transparent" IsLocked="True">
                <ToolBar Background="Transparent" Band="0" BandIndex="0"
                         Loaded="ToolBar_Loaded">
                    <!-- View -->
                    <Button Content="🔍 Fit" Click="ResetView_Click" ToolTip="Fit entire layout in view"
                            Padding="6,2" Margin="1,0"/>
                    <Button Content="⊕ Center" Click="CenterView_Click" ToolTip="Center view on layout"
                            Padding="6,2" Margin="1,0"/>
                    <Separator/>
                    <!-- Tools -->
                    <ToggleButton x:Name="BtnProbeMode" Content="📍 Probes" Click="DefineProbes_Click"
                                  ToolTip="Toggle probe placement mode" Padding="6,2" Margin="1,0"/>
                    <ToggleButton x:Name="BtnCapMode" Content="🔷 Capacitors" Click="DefineCapacitors_Click"
                                  ToolTip="Toggle capacitor placement mode" Padding="6,2" Margin="1,0"/>
                    <Separator/>
                    <Button x:Name="BtnUndo" Content="↩ Undo" Click="UndoLast_Click" ToolTip="Remove last placed probe or capacitor (Del)"
                            Padding="6,2" Margin="1,0" Visibility="Collapsed"/>
                    <Button x:Name="BtnClear" Content="🗑 Clear" Click="ClearAll_Click" ToolTip="Clear all probes or capacitors (Shift+C)"
                            Padding="6,2" Margin="1,0" Visibility="Collapsed"/>
                    <Separator/>
                    <Button Content="📋 Domains" Click="ManageDomains_Click" ToolTip="View and manage power domains"
                            Padding="6,2" Margin="1,0"/>
                    <Button Content="⚙ Settings" Click="Settings_Click" ToolTip="Board parameters"
                            Padding="6,2" Margin="1,0"/>
                    <Button Content="📊 PDN Impedance" Click="PdnImpedance_Click" ToolTip="PDN impedance analysis"
                            Padding="6,2" Margin="1,0"/>
                </ToolBar>
            </ToolBarTray>
        </DockPanel>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#FF2D2D30">
            <TextBlock x:Name="StatusText" Foreground="White" Text="Ready"/>
            <Separator/>
            <TextBlock x:Name="ZoomText" Foreground="White" Text="Zoom: 100%"/>
            <Separator/>
            <TextBlock x:Name="CoordsText" Foreground="White" Text="X: 0  Y: 0"/>
        </StatusBar>

        <!-- Main Content -->
        <Grid x:Name="MainGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- DXF Canvas -->
            <Border Grid.Column="0" Background="#FF1A1A1A" ClipToBounds="True"
                    MouseWheel="Canvas_MouseWheel"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    MouseMove="Canvas_MouseMove"
                    MouseRightButtonDown="Canvas_MouseRightButtonDown"
                    MouseRightButtonUp="Canvas_MouseRightButtonUp">
                <Canvas x:Name="DxfCanvas" Background="Transparent" RenderTransformOrigin="0,0">
                    <Canvas.RenderTransform>
                        <MatrixTransform x:Name="CanvasTransform"/>
                    </Canvas.RenderTransform>
                </Canvas>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#FF3E3E42"/>

            <!-- Right Panel: Layers + Info -->
            <DockPanel Grid.Column="2" Background="#FF2D2D30">
                <!-- Layers Header -->
                <StackPanel DockPanel.Dock="Top" Margin="4">
                    <TextBlock Text="Layers" FontWeight="Bold" FontSize="14" Foreground="White" Margin="0,4,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="All" Click="LayersSelectAll_Click" Width="40" Margin="0,0,4,0"
                                Background="#FF3E3E42" Foreground="White" BorderThickness="0"/>
                        <Button Content="None" Click="LayersSelectNone_Click" Width="40"
                                Background="#FF3E3E42" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Layers List -->
                <ListBox x:Name="LayersList" Background="Transparent" Foreground="White" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                      Foreground="White" Checked="LayerVisibilityChanged" Unchecked="LayerVisibilityChanged"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
