<Window x:Class="WpfApp.DomainSelectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Power Domain" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="#FF2D2D30" MinWidth="340">
    <StackPanel Margin="16">
        <TextBlock x:Name="lblMessage" Foreground="White" Margin="0,0,0,10" TextWrapping="Wrap"
                   Text="Select an existing power domain or type a new name:"/>
        <ComboBox x:Name="cmbDomains" IsEditable="True" MinWidth="280" Margin="0,0,0,16"
                  FontSize="13" Height="28"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0" Click="btnOk_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Click="btnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
